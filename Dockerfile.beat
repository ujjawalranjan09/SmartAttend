# SmartAttend — Celery beat scheduler Dockerfile.
# Render Background Worker that runs the periodic-task scheduler.
FROM python:3.11-slim

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends libgl1 libglib2.0-0 gcc \
    && rm -rf /var/lib/apt/lists/*

COPY apps/backend/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY apps/backend/ .

CMD ["celery", "-A", "app.tasks.celery_app.celery_app", "beat", "--loglevel=info"]
