# ─────────────────────────────────────────────
# SmartAttend — Environment Variables Template
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# ─────────────────────────────────────────────
# App Configuration
# ─────────────────────────────────────────────

# Runtime environment: development | staging | production
APP_ENV=development

# Application display name
APP_NAME=SmartAttend

# JWT signing secret (min 32 chars). REQUIRED in production.
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

# JWT algorithm (HS256 is default, RS256 for asymmetric keys)
ALGORITHM=HS256

# Access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token lifetime in days
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────

# PostgreSQL connection URL (asyncpg driver). REQUIRED in production.
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/smartattend

# Connection pool size (per worker)
DATABASE_POOL_SIZE=20

# Extra connections beyond pool_size (0 = no overflow)
DATABASE_MAX_OVERFLOW=0

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────

# Redis URL for caching and QR token storage
REDIS_URL=redis://localhost:6379/0

# QR token TTL in seconds (attendance QR codes expire after this)
QR_TOKEN_TTL_SECONDS=120

# ─────────────────────────────────────────────
# ML Service (Face Recognition / Anomaly Detection)
# ─────────────────────────────────────────────

# Face recognition microservice URL
ML_SERVICE_URL=http://localhost:8001

# Face similarity threshold (0.0-1.0) for matching faces
FACE_SIMILARITY_THRESHOLD=0.60

# Proxy attendance anomaly detection threshold (0.0-1.0)
PROXY_ANOMALY_THRESHOLD=0.75

# ─────────────────────────────────────────────
# Storage (AWS S3 / Cloudflare R2)
# ─────────────────────────────────────────────

# Storage backend: s3 | local
STORAGE_PROVIDER=s3

# AWS credentials (REQUIRED if storage_provider=s3)
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret

# AWS region for S3 bucket
AWS_REGION=ap-south-1

# S3 bucket name for storing media files
S3_BUCKET_NAME=smartattend-media

# ─────────────────────────────────────────────
# SMS / Twilio
# ─────────────────────────────────────────────

# SMS provider (twilio)
SMS_PROVIDER=twilio

# Twilio Account SID (REQUIRED for SMS)
TWILIO_ACCOUNT_SID=your-sid

# Twilio Auth Token (REQUIRED for SMS)
TWILIO_AUTH_TOKEN=your-token

# Twilio phone number to send SMS from (REQUIRED for SMS)
TWILIO_FROM_NUMBER=+1234567890

# ─────────────────────────────────────────────
# Email / SMTP
# ─────────────────────────────────────────────

# Sender email address for notifications
EMAIL_FROM=noreply@smartattend.in

# SMTP server hostname
SMTP_HOST=smtp.gmail.com

# SMTP server port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP username (leave empty to use console fallback in development)
SMTP_USER=your-email

# SMTP password (leave empty to use console fallback in development)
SMTP_PASSWORD=your-password

# ─────────────────────────────────────────────
# TOTP (Time-based One-Time Password)
# ─────────────────────────────────────────────

# TOTP issuer name shown in authenticator apps
TOTP_ISSUER=SmartAttend

# ─────────────────────────────────────────────
# Celery (Background Tasks)
# ─────────────────────────────────────────────

# Celery broker URL (Redis instance for task queue)
CELERY_BROKER_URL=redis://localhost:6379/1

# Celery result backend (Redis instance for task results)
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─────────────────────────────────────────────
# Monitoring (Optional)
# ─────────────────────────────────────────────

# Sentry DSN for error tracking (leave empty to disable)
SENTRY_DSN=
